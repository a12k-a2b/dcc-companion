<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="club.daylightcomputer.companion"
    android:versionCode="2"
    android:versionName="0.2">

    <uses-sdk android:minSdkVersion="26" android:targetSdkVersion="33" />

    <!-- The butler fetches the shelf and downloads dishes. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- "A friend brought a dish" — quiet notifications, user-approved. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- One-tap installs: the Companion hands dishes to Android's own
         installer. Android still shows its confirmation — the Companion
         never installs silently. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Reschedule the shelf-watch job after a reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- The inspector-at-home must see what's installed to detect
         collisions. The shelf grows over time, so the specific package
         names can't be declared ahead of time. This app never ships
         through Play (homebrew, sideloaded), so QUERY_ALL_PACKAGES is
         acceptable — and everything it learns stays on the tablet. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <application android:label="Club Companion">

        <!-- The front room: the club website, full-screen. Home IS the shelf. -->
        <activity
            android:name=".ClubActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The staff room: butler, inspector, reporter, and the counter. -->
        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <!-- A web dish served full-screen. Exported so the owner's Mac can
             put a dish on the glass over adb (`daylight open`) — it renders
             pages and grants nothing. -->
        <activity
            android:name=".DishWebActivity"
            android:exported="true" />

        <service
            android:name=".ShelfJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true" />

        <service
            android:name=".CounterJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true" />

        <receiver android:name=".InstallReceiver" android:exported="false" />

        <receiver android:name=".BootReceiver" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
